# Which key you need depends on model choice:
#   openrouter/* models → OPENROUTER_API_KEY
#   anthropic/* models  → ANTHROPIC_API_KEY
OPENROUTER_API_KEY=sk-or-v1-...
ANTHROPIC_API_KEY=sk-ant-...
# Optional: FMP API key for fundamental data
FMP_API_KEY=
# Git branch prefix for autoresearch runs
BRANCH_PREFIX=autoresearch
# Mode: "elenchus" | "vanilla" | "ab" (runs both, compares)
MODE=ab
